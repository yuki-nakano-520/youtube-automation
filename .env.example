ANTHROPIC_API_KEY=your_api_key_here
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER_ID=3

# 背景動画取得用APIキー（どちらか一方があればOK・両方無料）
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ──────────────────────────────────────────
# 自動投稿スケジュール設定（scheduler.py で使用）
# ──────────────────────────────────────────

# 投稿するジャンルの順番（カンマ区切り）
# 利用可能: trivia, history, science, money, english
POST_GENRES_CYCLE=trivia,history,science,money,english

# 投稿時刻（カンマ区切りで複数指定可）
POST_TIMES=09:00

# 投稿曜日（カンマ区切り。例: 毎日=mon,tue,wed,thu,fri,sat,sun / 平日のみ=mon,tue,wed,thu,fri）
POST_DAYS=mon,tue,wed,thu,fri,sat,sun

# 公開設定（public / unlisted / private）
POST_PRIVACY=public

# 1回の実行で生成・投稿する本数
POST_COUNT_PER_RUN=1
